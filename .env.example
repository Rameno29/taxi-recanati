# Database
DATABASE_URL=postgresql://taxi:YOUR_PASSWORD@localhost:5432/taxi_recanati
DATABASE_URL_TEST=postgresql://taxi:YOUR_PASSWORD@localhost:5433/taxi_recanati_test

# JWT — MUST be strong random secrets in production (generate with: openssl rand -hex 64)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Twilio (OTP verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated allowed origins (production only)
# ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
